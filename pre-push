#!/usr/bin/env bash
# pre-push hook: uses Claude Code to review outgoing commits and update CLAUDE.md if needed.
#
# Install:
#   cp pre-push ~/.githooks/pre-push
#   chmod +x ~/.githooks/pre-push
#   git config --global core.hooksPath ~/.githooks

set -euo pipefail

CLAUDE_MD="CLAUDE.md"

# Skip if claude CLI is not available
if ! command -v claude &>/dev/null; then
  echo "[pre-push] 'claude' CLI not found — skipping CLAUDE.md review."
  exit 0
fi

# Collect all commits being pushed and diff each against its parent.
# git passes lines of: <local ref> <local sha1> <remote ref> <remote sha1>
COMMITS=()
while read -r local_ref local_sha remote_ref remote_sha; do
  echo "[pre-push] Processing ref: $local_ref ($local_sha -> $remote_sha)"
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    # New branch — collect all commits reachable from local_sha with no remote
    mapfile -t NEW_COMMITS < <(git rev-list "$local_sha" --not --remotes 2>/dev/null || true)
    echo "[pre-push] New branch — found ${#NEW_COMMITS[@]} commit(s) with no remote counterpart."
    COMMITS+=("${NEW_COMMITS[@]}")
  else
    mapfile -t NEW_COMMITS < <(git rev-list "$remote_sha..$local_sha" 2>/dev/null || true)
    echo "[pre-push] Existing branch — found ${#NEW_COMMITS[@]} new commit(s) ahead of remote."
    COMMITS+=("${NEW_COMMITS[@]}")
  fi
  break  # only process the first ref
done

if [[ ${#COMMITS[@]} -eq 0 ]]; then
  echo "[pre-push] No new commits to review — skipping CLAUDE.md check."
  exit 0
fi

echo "[pre-push] Building diff for ${#COMMITS[@]} commit(s)..."

# Build diff by comparing each commit to its parent, skipping commits that
# only touch CLAUDE.md (e.g. the hook's own follow-up commits)
DIFF=""
for sha in "${COMMITS[@]}"; do
  CHANGED_FILES=$(git diff --name-only "${sha}^!" 2>/dev/null || true)
  if [[ "$CHANGED_FILES" == "$CLAUDE_MD" ]]; then
    echo "[pre-push] Skipping $sha — only contains CLAUDE.md changes."
    continue
  fi
  DIFF+=$(git diff "${sha}^!" 2>/dev/null || true)
done

if [[ -z "$DIFF" ]]; then
  echo "[pre-push] Empty diff — skipping CLAUDE.md check."
  exit 0
fi

# Read existing CLAUDE.md content (may be empty or missing)
CLAUDE_MD_CONTENT=""
if [[ -s "$CLAUDE_MD" ]]; then
  CLAUDE_MD_CONTENT=$(cat "$CLAUDE_MD")
fi

if [[ -z "$CLAUDE_MD_CONTENT" ]]; then
  echo "[pre-push] CLAUDE.md is empty or missing — will create from scratch if diff warrants it."
  PROMPT="You are setting up CLAUDE.md for a project.

CLAUDE.md is a project context file used by Claude Code (an AI coding assistant). It documents the things an AI assistant or new developer needs to know to work on the project: how to run, build, test, and lint the project; environment variables; architecture and key conventions; notable dependencies.

CLAUDE.md does not exist yet (or is empty). Based on the git diff below, create it from scratch. Include only what is concretely evidenced by the diff — do not invent or assume anything not present.

Write the new content directly to ./$CLAUDE_MD, then print one line summarising what you wrote.

Diff:
$DIFF"
else
  echo "[pre-push] CLAUDE.md found — checking diff against existing contents..."
  PROMPT="You are a technical reviewer. Your job is to check whether CLAUDE.md accurately reflects the current state of the codebase based on the changes in the diff below.

CLAUDE.md is a project context file used by Claude Code (an AI coding assistant). It should give an AI assistant or new developer an accurate understanding of the project: how it works, how to run it, its architecture, key conventions, commands, environment variables, and dependencies.

Current contents of CLAUDE.md:
---
$CLAUDE_MD_CONTENT
---

Read the diff below carefully. Then ask yourself: if someone read only CLAUDE.md, would they have an accurate and complete understanding of what this project now does and how it works?

For every statement in CLAUDE.md, check whether the diff contradicts it, makes it incomplete, or makes it stale. If so, update it.

For every meaningful change in the diff, check whether CLAUDE.md mentions it. If it introduces or changes behaviour, commands, architecture, configuration, or conventions that are not reflected in CLAUDE.md, add it.

Only skip changes that have no impact on how the project is understood or used: pure formatting, variable renames with no behavioural effect, or churn in generated/lock files.

If changes are needed, edit CLAUDE.md directly (it is at ./$CLAUDE_MD) before printing the report.

After your assessment, you MUST print a report in exactly this format (always — whether or not you made changes):
OUTCOME: UPDATED
REASONS:
- <reason for each change made>

or if no changes were needed:
OUTCOME: NO_CHANGE
REASONS:
- <reason each change was assessed and not documented>

Diff:
$DIFF"
fi

echo "[pre-push] Running Claude to review diff..."
SUMMARY=$(echo "$PROMPT" | claude --print --allowedTools "Edit,Write" 2>/dev/null || true)

echo ""
echo "[pre-push] Claude assessment:"
echo "$SUMMARY" | sed 's/^/  /'
echo ""

# Check if CLAUDE.md was modified or created by claude
if git diff --quiet "$CLAUDE_MD" 2>/dev/null && [[ -z "$(git ls-files --others --exclude-standard "$CLAUDE_MD")" ]]; then
  echo "[pre-push] No CLAUDE.md changes detected on disk."
  exit 0
fi

echo "[pre-push] Claude modified $CLAUDE_MD — creating follow-up commit."

git add "$CLAUDE_MD"
git commit -m "chore: update CLAUDE.md [pre-push]"

echo "[pre-push] Done. Run 'git push' again to push the CLAUDE.md update."
